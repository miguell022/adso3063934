generator client {
  provider = "prisma-client-js"
  output   = "../scr/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model console {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  image        String   @default("no-image.png")
  releaseDate  DateTime @db.Timestamp(0)
  manufacturer String
  description  String   @db.Text
  games        Game[]
}

model Game {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  cover       String   @default("no-cover.png")
  developer   String
  releaseDate DateTime @db.Timestamp(0)
  price       Float
  genre       String
  description String   @db.Text

  // Relations
  console_id Int
  console    console @relation(fields: [console_id], references: [id])
}
